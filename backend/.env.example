DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True

DB_NAME=devtrack
DB_USER=postgres
DB_PASSWORD=postgres-xxx
DB_HOST=127.0.0.1
DB_PORT=25432

DJANGO_CSRF_TRUSTED_ORIGINS=https://devtrakr.matrixai.xin

# Optional: absolute path to opencode binary if it is not in PATH
# OPENCODE_PATH=/usr/local/bin/opencode

# DashScope (Aliyun) — vision-capable LLM for AI Issue Wizard v2.
# Used to seed an LLMConfig row at deploy time; not read at request time.
# Get a key at https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Set to "True" to roll back the AI Issue Wizard to the 3-stage v1 pipeline.
# Used as an emergency switch during the 7-day v2 observation window.
AI_WIZARD_LEGACY=False
